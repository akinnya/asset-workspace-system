# ================================================
# asset-workspace-system 环境配置模板
# 默认本地文件存储，适合本地毕设环境直接启动
# ================================================

# 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_NAME=asset_workspace_system
DB_USERNAME=root
DB_PASSWORD=your_mysql_password_here

# Redis 配置（如未使用可保留默认）
REDIS_HOST=localhost
REDIS_PORT=6379

# 文件存储类型（默认 local）
FILE_STORAGE_TYPE=local
LOCAL_FILE_STORAGE_PATH=./data/uploads
